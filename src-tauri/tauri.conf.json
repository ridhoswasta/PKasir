{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PKasir",
  "version": "0.1.0",
  "identifier": "com.pkasir.pos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PKasir - A Full Featured Offline Cashier App",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "publisher": "PKasir",
    "category": "Business",
    "shortDescription": "PKasir - A Full Featured Offline Cashier App",
    "longDescription": "A Full Featured Offline Cashier App.",
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
